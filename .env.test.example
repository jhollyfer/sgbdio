# ============================================================
# AMBIENTE DE TESTES (e2e)
# ============================================================
# Testes rodam SEMPRE no host (nunca em container). Sobe somente
# postgres + redis em Docker e roda `npm run test:e2e` direto na
# máquina. Logo, hosts apontam para 127.0.0.1.
# ============================================================

NODE_ENV=test
PORT=3000

# ============================================
# POSTGRES (banco isolado de testes)
# ============================================
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=sgbdio_test

DATABASE_URL=postgres://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@127.0.0.1:5432/${DATABASE_NAME}

# ============================================
# URLS
# ============================================
APPLICATION_SERVER_PORT=3000
APPLICATION_CLIENT_PORT=5173
APPLICATION_SERVER_URL=http://localhost:3000
APPLICATION_CLIENT_URL=http://localhost:5173

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# CORS
# ============================================
# ALLOWED_ORIGINS=

# ============================================
# SEGURANÇA - JWT E COOKIES
# ============================================
# NUNCA use estas chaves em produção. Use ./credential-generator.sh.
COOKIE_DOMAIN=localhost
COOKIE_SECRET=GENERATE_YOUR_OWN_COOKIE_SECRET
JWT_PRIVATE_KEY=GENERATE_YOUR_OWN_PRIVATE_KEY
JWT_PUBLIC_KEY=GENERATE_YOUR_OWN_PUBLIC_KEY

# ============================================
# STORAGE
# ============================================
STORAGE_DRIVER=local
