# ============================================================
# DEFAULTS = DEV NATIVO NO HOST
# ============================================================
# Os hosts dos serviços (postgres/redis) apontam para 127.0.0.1
# porque o cenário padrão de desenvolvimento é:
#   - postgres + redis em Docker
#   - backend + frontend rodando direto na máquina
#
# Quando o stack inteiro sobe via Docker Compose, o compose
# sobrescreve DATABASE_URL e REDIS_URL com os hosts internos da
# rede Docker (postgres, redis). Não precisa editar este arquivo
# ao alternar entre os modos.
# ============================================================

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# POSTGRES
# ============================================
# Credenciais usadas pelo container postgres no compose e
# interpoladas em DATABASE_URL pelo setup.sh
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=sgbdio

# Em Docker Compose, o compose sobrescreve para
# postgres://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@postgres:5432/${DATABASE_NAME}
DATABASE_URL=postgres://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@127.0.0.1:5432/${DATABASE_NAME}

# ============================================
# PORTAS E URLS DA APLICAÇÃO
# ============================================
APPLICATION_SERVER_PORT=3000
APPLICATION_CLIENT_PORT=5173

APPLICATION_SERVER_URL=http://localhost:3000
APPLICATION_CLIENT_URL=http://localhost:5173

# ============================================
# CORS - ORIGENS PERMITIDAS
# ============================================
# Origens extras para CORS (separadas por ;). Suporta wildcard *.dominio.com.
# APPLICATION_SERVER_URL e APPLICATION_CLIENT_URL são permitidas automaticamente.
# ALLOWED_ORIGINS=https://app.example.com;*.example.com

# ============================================
# SEGURANÇA - JWT E COOKIES
# ============================================
# Use ./credential-generator.sh para gerar chaves RS256 + COOKIE_SECRET.
# NUNCA use os valores padrão em produção.
COOKIE_DOMAIN=localhost
COOKIE_SECRET=GENERATE_YOUR_OWN_COOKIE_SECRET
JWT_PRIVATE_KEY=GENERATE_YOUR_OWN_PRIVATE_KEY
JWT_PUBLIC_KEY=GENERATE_YOUR_OWN_PUBLIC_KEY

# ============================================
# REDIS (BullMQ — fila de e-mail)
# ============================================
# Em compose, sobrescrito para redis://redis:6379.
REDIS_URL=redis://localhost:6379

# ============================================
# SMTP (opcional)
# ============================================
# EMAIL_PROVIDER_HOST=smtp.example.com
# EMAIL_PROVIDER_PORT=587
# EMAIL_PROVIDER_USER=
# EMAIL_PROVIDER_PASSWORD=
# EMAIL_PROVIDER_FROM=no-reply@example.com
EMAIL_WORKER_CONCURRENCY=5

# ============================================
# STORAGE (Flydrive)
# ============================================
# local  → arquivos em backend/_storage/, servidos em /storage/{filename}
# s3     → AWS SDK + presigned URLs
STORAGE_DRIVER=local
# STORAGE_ENDPOINT=
# STORAGE_REGION=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# ============================================
# BOOTSTRAP ADMIN
# ============================================
# Usado pelo seed 0001-bootstrap-admin para criar o usuário MASTER inicial.
BOOTSTRAP_MASTER_EMAIL=master@example.com
BOOTSTRAP_MASTER_PASSWORD=Master@123
BOOTSTRAP_MASTER_NAME=Master

# ============================================
# FRONTEND (TanStack Start)
# ============================================
# SERVER_URL é consumido em SSR (server-only) — em compose, o app aponta
# para http://api:3000 internamente.
SERVER_URL=http://localhost:3000
VITE_APP_TITLE=sgbdio
