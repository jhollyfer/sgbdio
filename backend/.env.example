NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sgbdio

# URLs
APPLICATION_SERVER_URL=http://localhost:3000
APPLICATION_CLIENT_URL=http://localhost:5173

# CORS extras (separadas por ;)
# ALLOWED_ORIGINS=https://app.example.com;*.example.com

# Redis
REDIS_URL=redis://localhost:6379

# SMTP
# EMAIL_PROVIDER_HOST=smtp.example.com
# EMAIL_PROVIDER_PORT=587
# EMAIL_PROVIDER_USER=
# EMAIL_PROVIDER_PASSWORD=
# EMAIL_PROVIDER_FROM=no-reply@example.com
EMAIL_WORKER_CONCURRENCY=5

# Storage
STORAGE_DRIVER=local
# STORAGE_ENDPOINT=
# STORAGE_REGION=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# Bootstrap admin
BOOTSTRAP_MASTER_EMAIL=master@example.com
BOOTSTRAP_MASTER_PASSWORD=Master@123
BOOTSTRAP_MASTER_NAME=Master

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECRET=changeme

# JWT (RSA RS256, base64) — gere com: openssl genrsa -out priv.pem 2048 && openssl rsa -in priv.pem -pubout -out pub.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
