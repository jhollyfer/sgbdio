    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts --fix"
  },
